# Firebase Web app config — get these from the Firebase console:
#   Project settings -> Your apps -> Add app -> Web (</>)
# Reuse the existing `axol-work` project. Do NOT use the iOS API key here;
# the Web app has its own config. Copy this file to `.env.local` and fill in.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=axol-work.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=axol-work
VITE_FIREBASE_STORAGE_BUCKET=axol-work.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
