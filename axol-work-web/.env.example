# Firebase Web app config — get these from the Firebase console:
#   Project settings -> Your apps -> Add app -> Web (</>)
# Reuse the existing `axol-work` project. Do NOT use the iOS API key here;
# the Web app has its own config. Copy this file to `.env.local` and fill in.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=axol-work.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=axol-work
VITE_FIREBASE_STORAGE_BUCKET=axol-work.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# LinkedIn sign-in (Firebase Authentication → Sign-in method → OpenID Connect)
# 1. Create a LinkedIn app: https://www.linkedin.com/developers/apps
# 2. Enable product “Sign In with LinkedIn using OpenID Connect”
# 3. Auth → Redirect URLs: https://axol-work.firebaseapp.com/__/auth/handler
#    (and https://<your-authDomain>/__/auth/handler if different)
# 4. In Firebase, add OpenID Connect provider named `linkedin` (provider ID becomes oidc.linkedin)
#    Client ID / secret from LinkedIn; Issuer: https://www.linkedin.com/oauth
# 5. Optional override if you named the provider differently:
# VITE_LINKEDIN_PROVIDER_ID=oidc.linkedin
